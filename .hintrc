{
  "extends": [
    "development"
  ],
  "hints": {
    "apple-touch-icons": "off",
    "axe/aria": [
      "default",
      {
        "aria-required-children": "off"
      }
    ]
  },
  "browserslist": [
    "defaults",
    "not ie 11",
    "not and_ff <= 126",
    "not firefox <= 126",
    "not opera <= 110"
  ]
}